---
interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  {
    label: "Home",
    href: "#home",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M21 20C21 20.5523 20.5523 21 20 21H4C3.44772 21 3 20.5523 3 20V9.48907C3 9.18048 3.14247 8.88917 3.38606 8.69972L11.3861 2.47749C11.7472 2.19663 12.2528 2.19663 12.6139 2.47749L20.6139 8.69972C20.8575 8.88917 21 9.18048 21 9.48907V20ZM19 19V9.97815L12 4.53371L5 9.97815V19H19Z"></path></svg>`,
  },
  {
    label: "Skills",
    href: "#skills",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>`,
  },
  {
    label: "Projects",
    href: "#projects",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M4 5V19H20V7H11.5858L9.58579 5H4ZM12.4142 5H21C21.5523 5 22 5.44772 22 6V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3H10.4142L12.4142 5Z"></path></svg>`,
  },
  {
    label: "Background",
    href: "#background",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/></svg>`,
  },
  {
    label: "Contact",
    href: "#contact",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M21.7267 2.95694L16.2734 22.0432C16.1225 22.5716 15.7979 22.5956 15.5563 22.1126L11 13L1.9229 9.36919C1.41322 9.16532 1.41953 8.86022 1.95695 8.68108L21.0432 2.31901C21.5716 2.14285 21.8747 2.43866 21.7267 2.95694ZM19.0353 5.09647L6.81221 9.17085L12.4488 11.4255L15.4895 17.5068L19.0353 5.09647Z"></path></svg>`,
  },
];
---

<nav
  id="main-nav"
  class="sticky top-4 z-[100] bg-[#1414149c] border border border-[var(--white-icon-tr)] backdrop-blur-xl w-fit mx-auto rounded-full"
>
  <ul class="flex items-center gap-1 sm:gap-2 md:gap-3 lg:gap-5 py-3 px-4">
    {
      navItems.map((item) => (
        <li>
          <a
            id={`nav-${item.href.replace("#", "")}`}
            href={item.href}
            class="nav-link flex flex-col md:flex-row items-center gap-0 md:gap-2 text-[var(--white-icon)] hover:text-[var(--sec)] transition-colors text-xs sm:text-sm md:text-base px-2 sm:px-3 py-1 whitespace-nowrap"
          >
            <span class="md:hidden flex items-center justify-center w-5 h-5">
              <fragment set:html={item.icon} />
            </span>
            <span>{item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script is:inline>
  (function() {
    var sectionIds = ['home', 'skills', 'projects', 'background', 'contact'];
    var navHeight = 120;

    function getActiveSection() {
      var scrollTop = window.scrollY;
      var sections = [];

      for (var i = 0; i < sectionIds.length; i++) {
        var el = document.getElementById(sectionIds[i]);
        if (el) {
          sections.push({
            id: sectionIds[i],
            top: el.offsetTop,
            bottom: el.offsetTop + el.offsetHeight
          });
        }
      }

      var viewportMiddle = scrollTop + navHeight + 50;

      for (var j = sections.length - 1; j >= 0; j--) {
        if (viewportMiddle >= sections[j].top) {
          return sections[j].id;
        }
      }

      return 'home';
    }

    function setActive(id) {
      var links = document.querySelectorAll('.nav-link');
      for (var i = 0; i < links.length; i++) {
        links[i].classList.remove('active');
      }
      var active = document.getElementById('nav-' + id);
      if (active) {
        active.classList.add('active');
      }
    }

    function updateNav() {
      var activeId = getActiveSection();
      setActive(activeId);
    }

    var links = document.querySelectorAll('.nav-link');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', function(e) {
        e.preventDefault();
        var href = this.getAttribute('href');
        var id = href.replace('#', '');
        var target = document.getElementById(id);
        if (target) {
          var targetPos = target.offsetTop - navHeight;
          window.scrollTo({ top: targetPos, behavior: 'smooth' });
          setTimeout(function() { setActive(id); }, 350);
        }
      });
    }

    window.addEventListener('scroll', updateNav, { passive: true });
    
    setTimeout(function() {
      updateNav();
    }, 100);
  })();
</script>

<style>
  .nav-link.active {
    color: var(--sec) !important;
  }

  #main-nav ul {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #main-nav ul::-webkit-scrollbar {
    display: none;
  }
</style>
