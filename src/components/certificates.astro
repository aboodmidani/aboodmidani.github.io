---
interface Certificate {
  name: string;
  issuer: string;
  link?: string;
}

const certificates: Certificate[] = [
  {
    name: "Cybersecurity Professional Certificate",
    issuer: "Google",
  },
  {
    name: "Responsive Website",
    issuer: "University of London",
  },
  {
    name: "Programming with JavaScript",
    issuer: "Meta",
  },
  {
    name: "Version Control",
    issuer: "Meta",
  },
  {
    name: "Developing Front-End Apps with React",
    issuer: "IBM",
  },
  {
    name: "Vue.js 2: Working with APIs",
    issuer: "LinkedIn",
  },
  {
    name: "Vue.js: Testing and Debugging",
    issuer: "LinkedIn",
  },
  {
    name: "Agile Project Leadership",
    issuer: "LinkedIn",
  },
  {
    name: "Prompt Engineering: How to Talk to AIs",
    issuer: "LinkedIn",
  },
  {
    name: "Deep Dive into Open-Source Intelligence",
    issuer: "LinkedIn",
  },
];
---

<section id="certificates" class="py-12 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">Credentials</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Certificates</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        certificates.map((cert) => (
          <div class="bg-[#1414149c] rounded-xl p-4 border border-[var(--white-icon-tr)] hover:border-[var(--sec)] transition-colors flex items-start gap-3">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[var(--sec)] bg-opacity-20 flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-4 h-4 text-[var(--sec)]"
              >
                <path d="M12 15l-2-2 1.4-1.4L12 12.2l4.6-4.6L18 9l-6 6zM5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-[var(--white)] font-medium">{cert.name}</h4>
              <p class="text-sm text-[var(--white-icon)]">{cert.issuer}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
