---
interface Language {
  name: string;
  level: string;
  proficiency: string;
}

const languages: Language[] = [
  {
    name: "Arabic",
    level: "Native/Bilingual",
    proficiency: "100",
  },
  {
    name: "German",
    level: "Proficient (B2)",
    proficiency: "50",
  },
  {
    name: "English",
    level: "Fluent (C1)",
    proficiency: "90",
  },
];

const getProficiencyColor = (proficiency: string): string => {
  const level = parseInt(proficiency);
  if (level >= 90) return "var(--sec)";
  if (level >= 70) return "#8fff9f99";
  return "#8fff9f66";
};
---

<section id="languages" class="py-12 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">Communication</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Languages</h3>

    <div class="space-y-6">
      {
        languages.map((lang) => (
          <div class="bg-[#1414149c] rounded-xl p-6 border border-[var(--white-icon-tr)] hover:border-[var(--sec)] transition-colors">
            <div class="flex justify-between items-center mb-3">
              <h4 class="text-xl font-semibold text-[var(--white)]">{lang.name}</h4>
              <span class="text-sm text-[var(--sec)]">{lang.level}</span>
            </div>
            <div class="w-full bg-[#141414] rounded-full h-3">
              <div
                class="h-3 rounded-full transition-all duration-500"
                style={`width: ${lang.proficiency}%; background: ${getProficiencyColor(lang.proficiency)};`}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
